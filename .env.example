# Supabase - https://supabase.com 에서 프로젝트 생성 후 복사
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Toss Payments - https://developers.tosspayments.com
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_your_client_key
TOSS_SECRET_KEY=test_sk_your_secret_key

# Kakao OAuth - Supabase Auth > Providers > Kakao 에서 설정
NEXT_PUBLIC_KAKAO_REST_API_KEY=your_kakao_rest_api_key

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
